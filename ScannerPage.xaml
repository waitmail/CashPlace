<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:zxing="https://github.com/Redth/ZXing.Net.Maui"
             xmlns:controls="clr-namespace:ZXing.Net.Maui.Controls;assembly=ZXing.Net.MAUI.Controls"
             x:Class="CashPlace.ScannerPage"
             Title="Сканер"
             NavigationPage.HasNavigationBar="False">
             
    <Grid>
        <!-- Само окно камеры -->
        <controls:CameraBarcodeReaderView x:Name="scannerView" 
                                       BarcodesDetected="OnBarcodesDetected" />
                                       
        <!-- Кнопка закрытия -->
        <Button Text="Закрыть" 
                Clicked="OnCloseClicked" 
                VerticalOptions="End" 
                HorizontalOptions="Center" 
                Margin="0,0,0,40" 
                WidthRequest="150" />
    </Grid>
</ContentPage>